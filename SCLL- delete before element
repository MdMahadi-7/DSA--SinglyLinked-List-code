#include<iostream>
using namespace std;
class node{
  public:
  int data;
  node* next=nullptr;
};
node* head=nullptr;
node* tail=nullptr;
int main(){
  node* frs=new node();
  frs->data=1;
  frs->next=nullptr;

  node* sec=new node();
  sec->data=2;
  sec->next=nullptr;

  node* th=new node();
  th->data=3;
  th->next=nullptr;

  node* fr=new node();
  fr->data=4;
  fr->next=nullptr;


  head=frs;
  frs->next=sec;
  sec->next=th;
  th->next=fr;
  fr->next=head;
  tail=fr;

  for(node*ptr=head;;ptr=ptr->next){
    cout<<ptr->data<<" ";
    if(ptr->next==head) break;
  }

  cout<<endl;

  // delete before 3
  for(node* ptr=head,*prev1=nullptr,*prev2=nullptr;;prev2=prev1,prev1=ptr,ptr=ptr->next){
    if(ptr->data==3){
      prev2->next=ptr;
      delete prev1;
      break;
    }
  }

  for(node*ptr=head;;ptr=ptr->next){
    cout<<ptr->data<<" ";
    if(ptr->next==head) break;
  }
}
